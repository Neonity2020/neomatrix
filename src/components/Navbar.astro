---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="navbar">
  <div class="navbar__inner container">
    <a href={lang === 'en' ? '/en' : '/'} class="navbar__logo">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="8" fill="#6D28D9"/>
        <text x="6" y="23" font-size="18" font-family="Arial" font-weight="900" fill="white">N</text>
      </svg>
      <span class="navbar__brand">Neomatrix<span class="navbar__dot">.club</span></span>
    </a>

    <nav class="navbar__nav">
      <a href="#features" class="navbar__link">{t('nav.features')}</a>
      <a href="#how-it-works" class="navbar__link">{t('nav.howItWorks')}</a>
      <a href="#testimonials" class="navbar__link">{t('nav.testimonials')}</a>
      <a href="#pricing" class="navbar__link">{t('nav.pricing')}</a>
    </nav>

    <div class="navbar__actions">
      <a href={lang === 'zh' ? '/en' : '/'} class="navbar__link" style="margin-right: 20px; font-weight: 700;">
        {lang === 'zh' ? 'EN' : '中文'}
      </a>
      <a href="#pricing" class="btn btn--primary btn--sm">{t('nav.join')}</a>
    </div>

    <button class="navbar__hamburger" aria-label="菜单" id="hamburger">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="navbar__mobile-menu" id="mobileMenu">
    <a href={lang === 'zh' ? '/en' : '/'} style="color: var(--primary); font-weight: 700;">🌐 {lang === 'zh' ? 'Switch to English' : '切换至中文'}</a>
    <a href="#features">{t('nav.features')}</a>
    <a href="#how-it-works">{t('nav.howItWorks')}</a>
    <a href="#testimonials">{t('nav.testimonials')}</a>
    <a href="#pricing">{t('nav.pricing')}</a>
    <a href="#pricing" class="btn btn--primary" style="margin-top:8px;text-align:center;">{t('nav.join')}</a>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(109, 40, 217, 0.08);
    height: 72px;
  }

  .navbar__inner {
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .navbar__brand {
    font-size: 17px;
    font-weight: 800;
    color: var(--black);
    letter-spacing: -0.02em;
  }

  .navbar__dot {
    color: var(--primary);
  }

  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 32px;
    flex: 1;
    justify-content: center;
  }

  .navbar__link {
    font-size: 14px;
    font-weight: 500;
    color: var(--gray-700);
    transition: color 0.2s;
  }

  .navbar__link:hover {
    color: var(--primary);
  }

  .navbar__actions {
    flex-shrink: 0;
  }

  .navbar__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    padding: 4px;
  }

  .navbar__hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--black);
    border-radius: 2px;
    transition: all 0.2s;
  }

  .navbar__mobile-menu {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px 20px;
    background: white;
    border-top: 1px solid rgba(109,40,217,0.08);
  }

  .navbar__mobile-menu a {
    font-size: 16px;
    font-weight: 500;
    color: var(--gray-700);
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-100);
  }

  .navbar__mobile-menu.open {
    display: flex;
  }

  @media (max-width: 768px) {
    .navbar__nav,
    .navbar__actions {
      display: none;
    }

    .navbar__hamburger {
      display: flex;
    }
  }
</style>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.remove('open')));
</script>
