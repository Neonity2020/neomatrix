---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const testimonials = (t('testimonials.items') as unknown) as any[];
---

<section class="testimonials section" id="testimonials">
  <div class="container">
    <div class="testimonials__island island">
      <div class="testimonials__header" data-animate>
        <p class="section-eyebrow">{t('testimonials.eyebrow')}</p>
        <h2 class="section-title">{t('testimonials.title')}</h2>
        <p class="section-desc">{t('testimonials.desc')}</p>
      </div>

      <div class="testimonials__grid">
        {testimonials.map((item, i) => (
          <div class:list={['testimonials__card', item.featured && 'testimonials__card--featured']} data-animate style={`--delay: ${i * 80}ms`}>
            {item.featured && <div class="testimonials__badge">{t('testimonials.badge')}</div>}
            <div class="testimonials__stars">{'★'.repeat(item.stars)}</div>
            <p class="testimonials__quote">"{item.quote}"</p>
            <div class="testimonials__author">
              <div class="testimonials__avatar" style={`background: linear-gradient(135deg, ${item.color}, ${item.color}99)`}>
                {item.avatar}
              </div>
              <div>
                <div class="testimonials__name">{item.name}</div>
                <div class="testimonials__role">{item.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials__island {
    padding: 80px 64px;
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 64px;
  }

  .testimonials__header .section-desc {
    margin: 0 auto;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .testimonials__card {
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    padding: 28px;
    border: 1px solid rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.3s ease;
    position: relative;
  }

  .testimonials__card:hover {
    background: white;
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .testimonials__card--featured {
    grid-column: span 2;
    background: var(--primary-pale);
    border-color: rgba(109,40,217,0.15);
  }

  .testimonials__card--featured:hover {
    background: var(--primary-pale);
  }

  .testimonials__badge {
    display: inline-flex;
    align-items: center;
    background: var(--primary);
    color: white;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 100px;
    width: fit-content;
  }

  .testimonials__stars {
    color: #FFB800;
    font-size: 14px;
    letter-spacing: 2px;
  }

  .testimonials__quote {
    font-size: 15px;
    color: var(--gray-700);
    line-height: 1.75;
    flex: 1;
  }

  .testimonials__card--featured .testimonials__quote {
    font-size: 17px;
    color: var(--primary-dark);
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .testimonials__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .testimonials__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--black);
  }

  .testimonials__role {
    font-size: 12px;
    color: var(--gray-500);
    margin-top: 2px;
  }

  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--delay, 0ms), transform 0.6s ease var(--delay, 0ms);
  }
  [data-animate].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .testimonials__card--featured {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .testimonials__island {
      padding: 40px 16px;
    }
    .testimonials__grid {
      grid-template-columns: 1fr;
    }
    .testimonials__card--featured {
      grid-column: span 1;
    }
    .testimonials__header {
      margin-bottom: 40px;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.testimonials [data-animate]').forEach(el => observer.observe(el));
</script>
