---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const steps = (t('how.steps') as unknown) as any[];
---

<section class="how section" id="how-it-works">
  <div class="container">
    <div class="how__island island">
      <div class="how__header" data-animate>
        <p class="section-eyebrow">{t('how.eyebrow')}</p>
        <h2 class="section-title" set:html={t('how.title')}></h2>
        <p class="section-desc">{t('how.desc')}</p>
      </div>

      <div class="how__steps">
        {steps.map((step, i) => (
          <div class="how__step" data-animate style={`--delay: ${i * 120}ms`}>
            <div class="how__step-left">
              <div class="how__step-num">{step.num}</div>
              <div class="how__step-line" aria-hidden="true"></div>
            </div>
            <div class="how__step-content">
              <div class="how__step-icon">{step.icon}</div>
              <h3 class="how__step-title">{step.title}</h3>
              <p class="how__step-desc">{step.desc}</p>
              <div class="how__step-tags">
                {step.tags.map(tag => (
                  <span class="tag tag--primary">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="how__cta" data-animate>
        <a href="#pricing" class="btn btn--primary">{t('how.cta')}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .how__island {
    padding: 80px 64px;
  }

  .how__header {
    text-align: center;
    margin-bottom: 72px;
  }

  .how__header .section-desc {
    margin: 0 auto;
  }

  .how__steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 760px;
    margin: 0 auto 56px;
  }

  .how__step {
    display: flex;
    gap: 32px;
    align-items: flex-start;
  }

  .how__step-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }

  .how__step-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--primary);
    color: white;
    font-size: 14px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(109,40,217,0.3);
  }

  .how__step-line {
    width: 2px;
    flex: 1;
    min-height: 40px;
    background: linear-gradient(to bottom, var(--primary-pale), transparent);
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .how__step:last-child .how__step-line {
    display: none;
  }

  .how__step-content {
    padding-bottom: 48px;
    flex: 1;
  }

  .how__step:last-child .how__step-content {
    padding-bottom: 0;
  }

  .how__step-icon {
    font-size: 28px;
    margin-bottom: 12px;
  }

  .how__step-title {
    font-size: 22px;
    font-weight: 800;
    color: var(--black);
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .how__step-desc {
    font-size: 15px;
    color: var(--gray-500);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .how__step-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .how__cta {
    text-align: center;
  }

  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--delay, 0ms), transform 0.6s ease var(--delay, 0ms);
  }
  [data-animate].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .how__island {
      padding: 40px 16px;
    }
    .how__step {
      gap: 20px;
    }
    .how__step-title {
      font-size: 18px;
    }
    .how__header {
      margin-bottom: 48px;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 100);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.how [data-animate]').forEach(el => observer.observe(el));
</script>
