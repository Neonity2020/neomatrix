---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const features = (t('features.items') as unknown) as any[];
---

<section class="features section" id="features">
  <div class="container">
    <div class="features__island island">
      <div class="features__header" data-animate>
        <p class="section-eyebrow">{t('features.eyebrow')}</p>
        <h2 class="section-title" set:html={t('features.title')}></h2>
        <p class="section-desc">{t('features.desc')}</p>
      </div>

      <div class="features__grid">
        {features.map((f, i) => (
          <div class="features__card" data-animate style={`--delay: ${i * 80}ms`}>
            <div class="features__icon" style={`background: ${f.color}18; color: ${f.color}`}>
              {f.icon}
            </div>
            <h3 class="features__title">{f.title}</h3>
            <p class="features__desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .features__island {
    padding: 80px 64px;
  }

  .features__header {
    text-align: center;
    margin-bottom: 64px;
  }

  .features__header .section-desc {
    margin: 0 auto;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .features__card {
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    border: 1px solid rgba(0,0,0,0.06);
    transition: all 0.3s ease;
  }

  .features__card:hover {
    background: white;
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: rgba(109,40,217,0.1);
  }

  .features__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 20px;
  }

  .features__title {
    font-size: 17px;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .features__desc {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.7;
  }

  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease var(--delay, 0ms), transform 0.6s ease var(--delay, 0ms);
  }
  [data-animate].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .features__island {
      padding: 40px 16px;
    }
    .features__grid {
      grid-template-columns: 1fr;
    }
    .features__header {
      margin-bottom: 40px;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.features [data-animate]').forEach(el => observer.observe(el));
</script>
